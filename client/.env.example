# Copy this file to .env.local and fill in values.
# Never commit .env.local to version control.

# Backend API base URL.
# - Local dev: leave blank or set to http://localhost:8000
# - Production: set to your deployed backend URL, e.g. https://api.yourdomain.com
#   The Next.js rewrite in next.config.ts will proxy /api/* → this URL,
#   and the iframe will receive it via the ?apiUrl= query param.
NEXT_PUBLIC_API_URL=http://localhost:8000
